{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://triplog.local/workflow/request-state.schema.json",
  "title": "Harness Request State",
  "type": "object",
  "required": [
    "schema_version",
    "updated_at",
    "gate_mode",
    "subject_pattern",
    "roots",
    "current_batch_id",
    "tasks",
    "batches"
  ],
    "properties": {
      "schema_version": {
        "type": "string",
        "const": "1.2.0-draft"
      },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "gate_mode": {
      "type": "string",
      "enum": [
        "observe",
        "enforce"
      ]
    },
    "subject_pattern": {
      "type": "string"
    },
    "roots": {
      "type": "object",
      "required": [
        "claims",
        "evidence",
        "tickets",
        "dispatch"
      ],
      "properties": {
        "claims": {
          "type": "string"
        },
        "evidence": {
          "type": "string"
        },
        "tickets": {
          "type": "string"
        },
        "dispatch": {
          "type": "string"
        }
      }
    },
    "current_batch_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "tasks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/task"
      }
    },
    "batches": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/batch"
      }
    }
  },
  "$defs": {
    "batch": {
      "type": "object",
      "required": [
        "batch_id",
        "created_at",
        "items"
      ],
      "properties": {
        "batch_id": {
          "type": "string"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/item"
          }
        }
      }
    },
    "item": {
      "type": "object",
      "required": [
        "item_id",
        "title",
        "role_order",
        "retry_limit",
        "roles"
      ],
      "properties": {
        "item_id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "role_order": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "planner",
              "designer",
              "developer",
              "qa",
              "tester",
              "secretary"
            ]
          }
        },
        "retry_limit": {
          "type": "integer",
          "minimum": 1
        },
        "roles": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/roleState"
          }
        }
      }
    },
    "roleState": {
      "type": "object",
      "required": [
        "role",
        "required",
        "status",
        "attempt",
        "checklist",
        "claim_path",
        "done_ticket",
        "skip_ticket",
        "artifacts",
        "missing_items",
        "last_updated_at"
      ],
      "properties": {
        "role": {
          "type": "string",
          "enum": [
            "planner",
            "designer",
            "developer",
            "qa",
            "tester",
            "secretary"
          ]
        },
        "required": {
          "type": "boolean"
        },
        "status": {
          "type": "string",
          "enum": [
            "todo",
            "in_progress",
            "claimed",
            "done",
            "blocked",
            "skipped"
          ]
        },
        "attempt": {
          "type": "integer",
          "minimum": 0
        },
        "claim_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "done_ticket": {
          "$ref": "#/$defs/ticketState"
        },
        "skip_ticket": {
          "$ref": "#/$defs/ticketState"
        },
        "predecessor_roles": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "checklist": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/checkItem"
          }
        },
        "artifacts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifact"
          }
        },
        "missing_items": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "last_error": {
          "type": [
            "string",
            "null"
          ]
        },
        "last_updated_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "task": {
      "type": "object",
      "required": [
        "task_id",
        "task_subject",
        "batch_id",
        "item_id",
        "role",
        "lifecycle",
        "last_event_at"
      ],
      "properties": {
        "task_id": {
          "type": "string"
        },
        "task_subject": {
          "type": [
            "string",
            "null"
          ]
        },
        "task_description": {
          "type": [
            "string",
            "null"
          ]
        },
        "teammate_name": {
          "type": [
            "string",
            "null"
          ]
        },
        "team_name": {
          "type": [
            "string",
            "null"
          ]
        },
        "batch_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "item_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "role": {
          "type": [
            "string",
            "null"
          ]
        },
        "lifecycle": {
          "type": "string",
          "enum": [
            "created",
            "completion_blocked",
            "completed"
          ]
        },
        "last_event_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "ticketState": {
      "type": "object",
      "required": [
        "status",
        "path",
        "validated_at",
        "validated_by"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "none",
            "issued",
            "rejected"
          ]
        },
        "path": {
          "type": [
            "string",
            "null"
          ]
        },
        "validated_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "validated_by": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "checkItem": {
      "type": "object",
      "required": [
        "id",
        "label",
        "command",
        "status"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "command": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "pass",
            "fail"
          ]
        },
        "evidence_paths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      }
    },
    "artifact": {
      "type": "object",
      "required": [
        "kind",
        "path",
        "mtime"
      ],
      "properties": {
        "kind": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "mtime": {
          "type": "string",
          "format": "date-time"
        },
        "sha256": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
