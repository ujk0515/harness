{
  "schema_version": "1.0.0-draft",
  "roles": {
    "planner": [
      {
        "id": "planning_doc_exists",
        "label": "기획서 파일 존재",
        "command": "node .claude/scripts/validator.js check file_exists workspace/planning/A-planning-doc.md"
      },
      {
        "id": "planner_claim_exists",
        "label": "planner claim 존재",
        "command": "node .claude/scripts/validator.js check file_exists workspace/claims/{batch_id}/{item_id}/planner.claim.json"
      },
      {
        "id": "wf_evidence_exists",
        "label": "와이어프레임 evidence 존재",
        "command": "node .claude/scripts/validator.js check file_exists workspace/evidence/planner/{batch_id}/{item_id}/wf-export.json"
      },
      {
        "id": "desc_evidence_exists",
        "label": "설명 Board evidence 존재",
        "command": "node .claude/scripts/validator.js check file_exists workspace/evidence/planner/{batch_id}/{item_id}/desc-export.json"
      },
      {
        "id": "planner_state_done",
        "label": "request-state 내 planner status = done",
        "command": "node .claude/scripts/validator.js check json_field_equals workspace/planning/request-state.json batches.{batch_index}.items.{item_index}.roles.{role_index}.status done"
      }
    ],
    "designer": [
      {
