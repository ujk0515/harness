{
  "schema_version": "1.2.0",
  "roles": {
    "planner": [
      {
        "id": "planner_process_reads_all",
        "label": "planner transcript에 workboard/config/benchmark Read 호출 모두 존재",
        "command": "node .claude/scripts/validator.js check planner_process_reads_all {agent_transcript_path}"
      },
      {
        "id": "planner_process_write_planning_doc",
        "label": "planner transcript에 A-planning-doc.md 쓰기 호출 존재",
        "command": "node .claude/scripts/validator.js check transcript_touch {agent_transcript_path} workspace/planning/A-planning-doc.md"
      },
      {
        "id": "planner_process_claim_after_doc",
        "label": "planner claim 쓰기 호출이 planning-doc 쓰기 이후에 존재",
        "command": "node .claude/scripts/validator.js check transcript_touch_after {agent_transcript_path} workspace/planning/A-planning-doc.md workspace/claims/{batch_id}/{item_id}/planner.claim.json"
      },
      {
        "id": "planner_process_evidence_all",
        "label": "planner transcript에 wf/desc evidence 쓰기 호출 모두 존재",
        "command": "node .claude/scripts/validator.js check planner_process_evidence_all {agent_transcript_path} {batch_id} {item_id}"
      },
      {
        "id": "planner_process_no_wf_desc_removal",
        "label": "planner transcript에 wf_/desc_* 삭제/재할당 호출 없음",
        "command": "node .claude/scripts/validator.js check transcript_no_wf_desc_removal {agent_transcript_path}"
      },
      {
        "id": "planner_wf_export_valid",
        "label": "planner wf-export evidence: 최신 + type/board_id/board_name 유효",
        "when_action_not": "NO_CHANGE",
        "command": "node .claude/scripts/validator.js check planner_wf_export_valid workspace/evidence/planner/{batch_id}/{item_id}/wf-export.json {dispatch_created_at}"
      },
      {
        "id": "planner_desc_export_valid",
        "label": "planner desc-export evidence: 최신 + type/board_id/board_name 유효",
        "when_action_not": "NO_CHANGE",
        "command": "node .claude/scripts/validator.js check planner_desc_export_valid workspace/evidence/planner/{batch_id}/{item_id}/desc-export.json {dispatch_created_at}"
      },
      {
        "id": "planner_boards_valid",
        "label": "planner boards 유효성 (pair_match + board_name + action_consistency + wf_match + multi_screen + retry_preserves)",
        "command": "node .claude/scripts/validator.js check planner_boards_valid workspace/claims/{batch_id}/{item_id}/planner.claim.json workspace/planning/A-planning-doc.md workspace/evidence/planner/{batch_id}/{item_id} {item_id}"
      },
      {
        "id": "planner_planning_doc_valid",
        "label": "A-planning-doc.md: 표준 섹션 존재 + 내용 해시 변경",
        "command": "node .claude/scripts/validator.js check planner_planning_doc_valid workspace/planning/A-planning-doc.md workspace/evidence/planner/{batch_id}/{item_id}/content-hashes.json"
      },
      {
        "id": "planner_penpot_boards_live",
        "label": "planner claim의 wf_/desc_boards가 .penpot-boards.json 실제 존재 리스트에 모두 포함",
        "when_action_not": "NO_CHANGE",
        "command": "node .claude/scripts/validator.js check penpot_boards_present workspace/claims/{batch_id}/{item_id}/planner.claim.json planner"
      },
      {
        "id": "planner_boards_snapshot_recent",
        "label": "planner boards-snapshot evidence가 현재 시도 이후 갱신됨",
        "command": "node .claude/scripts/validator.js check mtime_after workspace/evidence/planner/{batch_id}/{item_id}/boards-snapshot.json {dispatch_created_at}"
      },
      {
        "id": "planner_claim_recent",
        "label": "planner claim 파일이 현재 시도 이후 갱신됨",
        "command": "node .claude/scripts/validator.js check mtime_after workspace/claims/{batch_id}/{item_id}/planner.claim.json {dispatch_created_at}"
      },
      {
        "id": "planner_claim_covers_item",
        "label": "planner claim의 covered_items에 현재 item_id가 포함됨",
        "command": "node .claude/scripts/validator.js check json_array_contains workspace/claims/{batch_id}/{item_id}/planner.claim.json covered_items {item_id}"
      },
      {
        "id": "planner_claim_fields_all",
        "label": "planner claim 필드 전체 유효 (export_shape_summary/read_log/action_rationale/planning_doc_sections/designer_required/design_reason/developer_ready/tester_required/tester_reason/user_raw/pre_review)",
        "command": "node .claude/scripts/validator.js check planner_claim_fields_all workspace/claims/{batch_id}/{item_id}/planner.claim.json"
      },
      {
        "id": "planner_claim_arrays_all",
        "label": "planner claim 배열 전체 유효 (reference_flows/expected_user_path/critical_states/avoid_patterns: 각 min2 + 최소길이 + 중복없음 + 품질)",
        "command": "node .claude/scripts/validator.js check planner_claim_arrays_all workspace/claims/{batch_id}/{item_id}/planner.claim.json"
      },
      {
        "id": "planner_routing_valid",
        "label": "planner claim 라우팅 유효 (designer_skip_valid + tester_required_consistency)",
        "command": "node .claude/scripts/validator.js check planner_routing_valid workspace/claims/{batch_id}/{item_id}/planner.claim.json workspace/planning/request-workboard.md {item_id}"
      },
      {
        "id": "planner_claim_missing_items_empty",
        "label": "planner claim missing_items가 비어 있음",
        "command": "node .claude/scripts/validator.js check json_array_empty workspace/claims/{batch_id}/{item_id}/planner.claim.json missing_items"
      },
      {
        "id": "planner_request_coverage_all",
        "label": "planner claim request_coverage 형식 유효 + action!=NO_CHANGE 시 작업 보드 원문 80% 기획서에 포함",
        "command": "node .claude/scripts/validator.js check planner_request_coverage_all workspace/claims/{batch_id}/{item_id}/planner.claim.json workspace/planning/request-workboard.md {item_id} workspace/planning/A-planning-doc.md"
      },
      {
        "id": "planner_claim_no_deferral_phrases",
        "label": "claim에 유예 표현 없음",
        "command": "node .claude/scripts/validator.js check no_deferral_phrases workspace/claims/{batch_id}/{item_id}/planner.claim.json"
      },
      {
        "id": "planner_desc_no_forbidden_terms",
        "label": "desc-export evidence에 구현 용어(API/DB/hook/props 등) 없음",
        "command": "node .claude/scripts/validator.js check desc_no_forbidden_terms workspace/evidence/planner/{batch_id}/{item_id}/desc-export.json"
      },
      {
        "id": "planner_export_shape_summary_schema",
        "label": "claim.export_shape_summary에 필수 키(wf_result/desc_result/overlaps/overflow) 포함",
        "command": "node .claude/scripts/validator.js check json_object_has_keys workspace/claims/{batch_id}/{item_id}/planner.claim.json export_shape_summary wf_result desc_result overlaps overflow"
      },
      {
        "id": "planner_workboard_item_has_quote",
        "label": "작업 보드 item 행에 사용자 원문 인용 포함",
        "command": "node .claude/scripts/validator.js check workboard_item_has_quote workspace/planning/request-workboard.md {item_id}"
      },
      {
        "id": "planner_claim_hash_changed",
        "label": "planner.claim.json 내용 해시가 이전 시도와 다름",
        "command": "node .claude/scripts/validator.js check hash_record_and_compare workspace/claims/{batch_id}/{item_id}/planner.claim.json workspace/evidence/planner/{batch_id}/{item_id}/content-hashes.json"
      },
      {
        "id": "planner_write_whitelist_respected",
        "label": "planner가 상위 설정/규칙 파일에 Write/Edit하지 않음",
        "command": "node .claude/scripts/validator.js check transcript_no_forbidden_writes {agent_transcript_path} workspace/planning/request-workboard\\.md workspace/planning/project-config\\.md workspace/planning/A-benchmark\\.md workspace/lessons-learned\\.md ^workflow/ ^workspace/design/ ^workspace/reviews/ ^workspace/testing/ ^workspace/reports/ ^\\.claude/"
      },
      {
        "id": "planner_pre_review_bundle",
        "label": "plan 모드: user_raw_request 원문 일치 + pre_review_qa 적용 확인",
        "when_mode": "plan",
        "command": "node .claude/scripts/validator.js check planner_pre_review_bundle workspace/claims/{batch_id}/{item_id}/planner.claim.json workspace/planning/.pre-review/{batch_id}/{item_id}.json"
      },
      {
        "id": "planner_revise_bundle",
        "label": "revise 모드: ux-review/dev-review/qa-review Read + prior_review_addressed + review_response_decisions/review_source",
        "when_mode": "revise",
        "command": "node .claude/scripts/validator.js check planner_revise_bundle {agent_transcript_path} workspace/claims/{batch_id}/{item_id}/planner.claim.json workspace/design/A-uiux-review.md workspace/planning/A-planning-doc.md workspace/reviews/{batch_id}/{item_id}"
      },
      {
        "id": "planner_loop_b_revise_bundle",
        "label": "루프 B revise: 4인 리뷰 번들 + assignments 유효 + 분류 + 처리된 태스크 커버",
        "when_mode": "revise",
        "command": "node .claude/scripts/validator.js check planner_loop_b_revise_bundle {batch_id} {item_id} workspace/claims/{batch_id}/{item_id}/planner.claim.json"
      },
      {
        "id": "planner_review_bundle",
        "label": "review 모드: planner-review.md 존재 + UIUX/디스크립션/기획서 섹션 + 최신",
        "when_mode": "review",
        "command": "node .claude/scripts/validator.js check planner_review_bundle workspace/reviews/{batch_id}/{item_id}/planner-review.md {dispatch_created_at}"
      },
      {
        "id": "planner_state_done",
        "label": "request-state 내 planner status = done",
        "command": "node .claude/scripts/validator.js check json_field_equals workspace/planning/request-state.json batches.{batch_index}.items.{item_index}.roles.{role_index}.status done"
      }
    ],
    "designer": [
      {
        "id": "designer_process_common_reads",
        "label": "designer transcript에 workboard/A-planning-doc Read 호출 모두 존재",
        "command": "node .claude/scripts/validator.js check designer_process_common_reads {agent_transcript_path}"
      },
      {
        "id": "designer_process_apply_writes",
        "label": "designer apply transcript: design-export + boards 작성 + claim이 design-export 이후",
        "when_mode": "apply",
        "command": "node .claude/scripts/validator.js check designer_process_apply_writes {agent_transcript_path} {batch_id} {item_id}"
      },
      {
        "id": "designer_process_no_wf_desc_removal",
        "label": "designer apply transcript에 wf_/desc_* 삭제/재할당 호출 없음",
        "when_mode": "apply",
        "command": "node .claude/scripts/validator.js check transcript_no_wf_desc_removal {agent_transcript_path}"
      },
      {
        "id": "designer_claim_recent",
        "label": "designer claim 파일이 현재 시도 이후 갱신됨",
        "command": "node .claude/scripts/validator.js check mtime_after workspace/claims/{batch_id}/{item_id}/designer.claim.json {dispatch_created_at}"
      },
      {
        "id": "designer_claim_covers_item",
        "label": "designer claim의 covered_items에 현재 item_id가 포함됨",
        "command": "node .claude/scripts/validator.js check json_array_contains workspace/claims/{batch_id}/{item_id}/designer.claim.json covered_items {item_id}"
      },
      {
        "id": "designer_apply_claim_fields",
        "label": "designer apply claim: developer_ready=Y + developer_targets/design_boards 비어있지 않음 + missing_items 비어있음",
        "when_mode": "apply",
        "command": "node .claude/scripts/validator.js check designer_apply_claim_fields workspace/claims/{batch_id}/{item_id}/designer.claim.json"
      },
      {
        "id": "designer_design_export_valid",
        "label": "designer design-export evidence: 최신 + type=design_export + board_id + board_name",
        "when_mode": "apply",
        "command": "node .claude/scripts/validator.js check designer_design_export_valid workspace/evidence/designer/{batch_id}/{item_id}/design-export.json {dispatch_created_at}"
      },
      {
        "id": "designer_boards_manifest_valid",
        "label": "designer boards.json: 최신 + design_boards 비어있지 않음",
        "when_mode": "apply",
        "command": "node .claude/scripts/validator.js check designer_boards_manifest_valid workspace/evidence/designer/{batch_id}/{item_id}/boards.json {dispatch_created_at}"
      },
      {
        "id": "designer_covers_planner_targets",
        "label": "designer claim.design_boards가 planner.design_target_boards 전부 커버",
        "when_mode": "apply",
        "command": "node .claude/scripts/validator.js check designer_covers_planner_targets workspace/claims/{batch_id}/{item_id}/designer.claim.json workspace/claims/{batch_id}/{item_id}/planner.claim.json"
      },
      {
        "id": "design_boards_match_wf_boards",
        "label": "planner.wf_boards 의 모든 screen_id 에 대응하는 design_* 존재",
        "when_mode": "apply",
        "command": "node .claude/scripts/validator.js check design_boards_match_wf_boards workspace/claims/{batch_id}/{item_id}/designer.claim.json workspace/claims/{batch_id}/{item_id}/planner.claim.json"
      },
      {
        "id": "designer_penpot_boards_live",
        "label": "designer claim의 design_boards가 .penpot-boards.json 실제 존재 리스트에 모두 포함 (30분 fresh)",
        "when_mode": "apply",
        "command": "node .claude/scripts/validator.js check penpot_boards_present workspace/claims/{batch_id}/{item_id}/designer.claim.json designer"
      },
      {
        "id": "design_below_wf_desc_coord",
        "label": "design_* y좌표가 wf_/desc_ bottom+120 이상이며 서로 겹치지 않고 같은 페이지",
        "when_mode": "apply",
        "command": "node .claude/scripts/validator.js check design_below_wf_desc workspace/evidence/designer/{batch_id}/{item_id}"
      },
      {
        "id": "designer_developer_ready_cross_check",
        "label": "designer developer_ready=Y 시 missing_items 공백 + planner 타겟 전원 커버 + wf 매칭 교차검증",
        "when_mode": "apply",
        "command": "node .claude/scripts/validator.js check developer_ready_cross_check workspace/claims/{batch_id}/{item_id}/designer.claim.json workspace/claims/{batch_id}/{item_id}/planner.claim.json"
      },
      {
        "id": "designer_review_claim_complete",
        "label": "designer review: claim(mode=review/review_score/review_approval/review_issues/review_summary) 완결",
        "when_mode": "review",
        "command": "node .claude/scripts/validator.js check review_claim_complete workspace/claims/{batch_id}/{item_id}/designer.claim.json"
      },
      {
        "id": "designer_review_score_gate_pass",
        "label": "designer review: A-uiux-review.md 점수 80점 이상 또는 review_approval=Y",
        "when_mode": "review",
        "command": "node .claude/scripts/validator.js check designer_review_score_gate workspace/design/A-uiux-review.md workspace/claims/{batch_id}/{item_id}/designer.claim.json 80"
      },
      {
        "id": "designer_review_loop_b_file_if_present",
        "label": "루프 B designer review: designer-review.md가 있으면 UIUX/디스크립션/기획서 보완점 섹션과 본문 120자 이상",
        "when_mode": "review",
        "command": "node .claude/scripts/validator.js check loop_b_review_bundle_complete {batch_id} {item_id}"
      },
      {
        "id": "designer_apply_loop_b_assignments_valid",
        "label": "루프 B designer apply (sync): assignments.json 유효",
        "when_mode": "apply",
        "command": "node .claude/scripts/validator.js check loop_b_assignments_valid {batch_id} {item_id}"
      },
      {
        "id": "designer_apply_loop_b_processed_assigned_tasks",
        "label": "루프 B designer apply (sync): claim.assigned_task_ids가 assignments.designer_tasks 전부 커버",
        "when_mode": "apply",
        "command": "node .claude/scripts/validator.js check claim_processed_assigned_tasks workspace/claims/{batch_id}/{item_id}/designer.claim.json workspace/reviews/{batch_id}/{item_id}/assignments.json designer"
      },
      {
        "id": "designer_state_done",
        "label": "request-state 내 designer status = done",
        "command": "node .claude/scripts/validator.js check json_field_equals workspace/planning/request-state.json batches.{batch_index}.items.{item_index}.roles.{role_index}.status done"
      }
    ],
    "developer": [
      {
        "id": "developer_process_read_workboard",
        "label": "developer transcript에 request-workboard.md Read 호출 존재",
        "command": "node .claude/scripts/validator.js check transcript_read {agent_transcript_path} workspace/planning/request-workboard.md"
      },
      {
        "id": "developer_process_read_config",
        "label": "developer transcript에 project-config.md Read 호출 존재",
        "command": "node .claude/scripts/validator.js check transcript_read {agent_transcript_path} workspace/planning/project-config.md"
      },
      {
        "id": "developer_process_read_planning_doc",
        "label": "developer transcript에 A-planning-doc.md Read 호출 존재",
        "command": "node .claude/scripts/validator.js check transcript_read {agent_transcript_path} workspace/planning/A-planning-doc.md"
      },
      {
        "id": "developer_process_claim_written",
        "label": "developer transcript에 developer claim Write/Edit 호출 존재",
        "command": "node .claude/scripts/validator.js check transcript_touch {agent_transcript_path} workspace/claims/{batch_id}/{item_id}/developer.claim.json"
      },
      {
        "id": "developer_process_claim_after_impl",
        "label": "developer transcript에서 claim Write가 evidence 생성 이후에 실행됨",
        "command": "node .claude/scripts/validator.js check transcript_touch_after {agent_transcript_path} workspace/evidence/developer/{batch_id}/{item_id} workspace/claims/{batch_id}/{item_id}/developer.claim.json"
      },
      {
        "id": "developer_claim_recent",
        "label": "developer claim 파일이 현재 시도 이후 갱신됨",
        "command": "node .claude/scripts/validator.js check mtime_after workspace/claims/{batch_id}/{item_id}/developer.claim.json {dispatch_created_at}"
      },
      {
        "id": "developer_claim_covers_item",
        "label": "developer claim의 covered_items에 현재 item_id가 포함됨",
        "command": "node .claude/scripts/validator.js check json_array_contains workspace/claims/{batch_id}/{item_id}/developer.claim.json covered_items {item_id}"
      },
      {
        "id": "developer_evidence_recent",
        "label": "developer evidence 디렉터리에 현재 시도 이후 생성/수정 산출물이 있음",
        "command": "node .claude/scripts/validator.js check dir_has_entries_after workspace/evidence/developer/{batch_id}/{item_id} {dispatch_created_at}"
      },
      {
        "id": "developer_review_file_has_uiux",
        "label": "루프 B developer review: developer-review.md에 UIUX 보완점 섹션 존재",
        "when_mode": "review",
        "command": "node .claude/scripts/validator.js check file_contains workspace/reviews/{batch_id}/{item_id}/developer-review.md UIUX 보완점"
      },
      {
        "id": "developer_review_file_has_desc",
        "label": "루프 B developer review: developer-review.md에 디스크립션(desc_*) 보완점 섹션 존재",
        "when_mode": "review",
        "command": "node .claude/scripts/validator.js check file_contains workspace/reviews/{batch_id}/{item_id}/developer-review.md 디스크립션"
      },
      {
        "id": "developer_review_file_has_plan",
        "label": "루프 B developer review: developer-review.md에 기획서 보완점 섹션 존재",
        "when_mode": "review",
        "command": "node .claude/scripts/validator.js check file_contains workspace/reviews/{batch_id}/{item_id}/developer-review.md 기획서 보완점"
      },
      {
        "id": "developer_review_recent",
        "label": "루프 B developer review: 파일이 현재 시도 이후 갱신됨",
        "when_mode": "review",
        "command": "node .claude/scripts/validator.js check mtime_after workspace/reviews/{batch_id}/{item_id}/developer-review.md {dispatch_created_at}"
      },
      {
        "id": "developer_state_done",
        "label": "request-state 내 developer status = done",
        "command": "node .claude/scripts/validator.js check json_field_equals workspace/planning/request-state.json batches.{batch_index}.items.{item_index}.roles.{role_index}.status done"
      }
    ],
    "qa": [
      {
        "id": "qa_process_read_workboard",
        "label": "qa transcript에 request-workboard.md Read 호출 존재",
        "command": "node .claude/scripts/validator.js check transcript_read {agent_transcript_path} workspace/planning/request-workboard.md"
