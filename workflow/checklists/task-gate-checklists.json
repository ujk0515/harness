{
  "schema_version": "1.2.0",
  "roles": {
    "planner": [
      {
        "id": "planner_process_read_workboard",
        "label": "planner transcript에 request-workboard.md Read 호출 존재",
        "command": "node .claude/scripts/validator.js check transcript_read {agent_transcript_path} workspace/planning/request-workboard.md"
      },
      {
        "id": "planner_process_read_config",
        "label": "planner transcript에 project-config.md Read 호출 존재",
        "command": "node .claude/scripts/validator.js check transcript_read {agent_transcript_path} workspace/planning/project-config.md"
      },
      {
        "id": "planner_process_read_benchmark_if_exists",
        "label": "A-benchmark.md가 있으면 planner transcript에 Read 호출 존재",
        "command": "node .claude/scripts/validator.js check transcript_read_if_exists {agent_transcript_path} workspace/planning/A-benchmark.md"
      },
      {
        "id": "planner_process_write_planning_doc",
        "label": "planner transcript에 A-planning-doc.md 쓰기 호출 존재",
        "command": "node .claude/scripts/validator.js check transcript_touch {agent_transcript_path} workspace/planning/A-planning-doc.md"
      },
      {
        "id": "planner_process_claim_after_doc",
        "label": "planner claim 쓰기 호출이 planning-doc 쓰기 이후에 존재",
        "command": "node .claude/scripts/validator.js check transcript_touch_after {agent_transcript_path} workspace/planning/A-planning-doc.md workspace/claims/{batch_id}/{item_id}/planner.claim.json"
      },
      {
        "id": "planner_process_wf_evidence_written",
        "label": "planner transcript에 wf-export evidence 쓰기 호출 존재",
        "command": "node .claude/scripts/validator.js check transcript_touch {agent_transcript_path} workspace/evidence/planner/{batch_id}/{item_id}/wf-export.json"
      },
      {
        "id": "planner_process_desc_evidence_written",
        "label": "planner transcript에 desc-export evidence 쓰기 호출 존재",
        "command": "node .claude/scripts/validator.js check transcript_touch {agent_transcript_path} workspace/evidence/planner/{batch_id}/{item_id}/desc-export.json"
      },
      {
        "id": "planner_process_no_wf_desc_removal",
        "label": "planner revise transcript에 wf_/desc_* 삭제/재할당 호출 없음",
        "when_mode": "revise",
        "command": "node .claude/scripts/validator.js check transcript_no_wf_desc_removal {agent_transcript_path}"
      },
      {
        "id": "planner_snapshot_before_exists",
        "label": "planner revise 시작 전 wf/desc snapshot-before evidence가 현재 시도 이후 갱신됨",
        "when_mode": "revise",
        "command": "node .claude/scripts/validator.js check mtime_after workspace/evidence/planner/{batch_id}/{item_id}/wf-desc-snapshot-before.json {dispatch_created_at}"
      },
      {
        "id": "planner_snapshot_after_exists",
        "label": "planner revise 종료 후 wf/desc snapshot-after evidence가 현재 시도 이후 갱신됨",
        "when_mode": "revise",
        "command": "node .claude/scripts/validator.js check mtime_after workspace/evidence/planner/{batch_id}/{item_id}/wf-desc-snapshot-after.json {dispatch_created_at}"
      },
      {
        "id": "planner_snapshot_preserves_wf_desc",
        "label": "planner revise 전후 snapshot 비교 시 기존 wf_/desc_* Board id가 유지됨",
        "when_mode": "revise",
        "command": "node .claude/scripts/validator.js check snapshot_preserves_ids workspace/evidence/planner/{batch_id}/{item_id}/wf-desc-snapshot-before.json workspace/evidence/planner/{batch_id}/{item_id}/wf-desc-snapshot-after.json"
