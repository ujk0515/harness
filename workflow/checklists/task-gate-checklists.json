      },
      {
        "id": "qa_process_read_planning_doc",
        "label": "qa transcript에 A-planning-doc.md Read 호출 존재",
        "command": "node .claude/scripts/validator.js check transcript_read {agent_transcript_path} workspace/planning/A-planning-doc.md"
      },
      {
        "id": "qa_process_claim_written",
        "label": "qa transcript에 qa claim Write/Edit 호출 존재",
