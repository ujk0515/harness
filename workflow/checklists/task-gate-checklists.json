        "id": "planner_claim_covers_item",
        "label": "planner claim의 covered_items에 현재 item_id가 포함됨",
        "command": "node .claude/scripts/validator.js check json_array_contains workspace/claims/{batch_id}/{item_id}/planner.claim.json covered_items {item_id}"
      },
      {
        "id": "planner_claim_has_wf_boards",
